# Agente 73 v4.0 — copiar a /opt/agente73/agente73/.env y completar.
# NUNCA commitear el .env real.

# --- Servicio ---
A73_HOST=127.0.0.1
A73_PORT=8091
A73_LOG_LEVEL=INFO

# --- Seguridad (OBLIGATORIO) ---
# Secreto compartido con el whatsapp-bridge para firmar el webhook
# (HMAC-SHA256 del cuerpo crudo en la cabecera X-Signature-256).
A73_HMAC_SECRET=
# Números autorizados en E.164, separados por comas. Vacío = nadie.
A73_WHITELIST=+34600000000
A73_RATE_LIMIT_PER_HOUR=30

# --- Estado ---
# auto: usa Redis si responde; si no, SQLite. En el VPS Redis ya corre en 6379.
A73_STORAGE=auto
A73_REDIS_URL=redis://127.0.0.1:6379/3

# --- Motor de subagentes ---
# Clon DEDICADO de stackposts-analysis (no el de producción):
A73_REPO_DIR=/opt/agente73/stackposts-analysis
A73_CLAUDE_BIN=claude
A73_CLAUDE_TIMEOUT=1800
# Fallback API directa para fases de texto si el CLI no está disponible:
ANTHROPIC_API_KEY=
A73_ANTHROPIC_MODEL=claude-sonnet-5

# --- Notificaciones ---
A73_BRIDGE_URL=http://127.0.0.1:8080
A73_BRIDGE_SEND_PATH=/send
A73_GMAIL_USER=holawebdoctor@gmail.com
# App password de Google (16 caracteres) — la contraseña normal da 535:
A73_GMAIL_APP_PASSWORD=
A73_NOTIFY_EMAIL_TO=leox433@gmail.com

# --- Entrega opcional por rama+PR (0/1) ---
A73_DELIVER_GIT_PR=0
